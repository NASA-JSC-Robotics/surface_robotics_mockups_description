<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:macro name="ctb" params="
    prefix:=''
    parent:=''
    *origin">

    <xacro:include filename="$(find mockups_launch_common)/urdf/mockups_launch_common_colors.xacro"/>


    <joint name="${prefix}ctb_joint" type="floating">
      <parent link="${parent}"/>
      <child link="${prefix}ctb"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <link name="${prefix}ctb">
      <inertial>
        <mass value="1.8"/>
        <inertia ixx="0.0505" ixy="0.0" ixz="0.0" iyy="0.0326" iyz="0.0" izz="0.0675"/>
      </inertial>
      <!-- body -->
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="-1.57 0 0"/>
        <geometry>
          <mesh filename="package://ctb/meshes/ctb_body.stl" scale="0.0254 0.0254 0.0254"/>
        </geometry>
        <xacro:color-white prefix="ctb_"/>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 0.0" rpy="1.57 0 0"/>
        <geometry>
          <mesh filename="package://ctb/meshes/ctb_body.stl"/>
        </geometry>
        <xacro:color-white prefix="ctb_"/>
      </collision>
      <!-- handle -->
      <visual>
        <origin xyz="0.0 0.08 0.264" rpy="1.57 0 0"/>
        <geometry>
          <mesh filename="package://ctb/meshes/ctb_handle.stl" scale="0.0254 0.0254 0.0254"/>
        </geometry>
        <xacro:color-red prefix="ctb_"/>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ctb/meshes/ctb_handle.stl"/>
        </geometry>
        <xacro:color-red prefix="ctb_"/>
      </collision>
    </link>
  </xacro:macro>
</robot>
