<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:macro name="ctb" params="
    name:='ctb'
    prefix:=''
    parent:=''
    *origin">

    <joint name="${prefix}${name}_joint" type="floating">
      <parent link="${parent}"/>
      <child link="${prefix}${name}"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <link name="${prefix}${name}">
      <inertial>
        <mass value="1.8"/>
        <inertia ixx="0.0505" ixy="0.0" ixz="0.0" iyy="0.0675" iyz="0.0" izz="0.0326"/>
      </inertial>
      <!-- body -->
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="-1.57 0 0"/>
        <geometry>
          <mesh filename="package://ctb/meshes/ctb_body.stl" scale="0.0254 0.0254 0.0254"/>
        </geometry>
        <material name="ctb_grey">
            <color rgba="1.0 1.0 1.0 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 0.0" rpy="1.57 0 0"/>
        <geometry>
          <mesh filename="package://ctb/meshes/ctb_body.stl"/>
        </geometry>
        <material name="ctb_grey">
            <color rgba="1.0 1.0 1.0 1.0"/>
        </material>
      </collision>
      <!-- handle -->
      <visual>
        <origin xyz="0.0 0.08 0.264" rpy="1.57 0 0"/>
        <geometry>
          <mesh filename="package://ctb/meshes/ctb_handle.stl" scale="0.0254 0.0254 0.0254"/>
        </geometry>
        <material name="red">
              <color rgba="1.0 0.0 0.0 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ctb/meshes/ctb_handle.stl"/>
        </geometry>
        <material name="red">
              <color rgba="1.0 0.0 0.0 1.0"/>
        </material>
      </collision>
    </link>
  </xacro:macro>
</robot>
