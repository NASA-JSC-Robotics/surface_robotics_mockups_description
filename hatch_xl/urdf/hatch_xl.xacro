<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:macro name="hatch_xl" params="
    prefix:=''
    parent:=''
    *origin">

    <joint name="${prefix}hatch_outer_frame_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}hatch_outer_frame"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <link name="${prefix}hatch_outer_frame">
      <!--TODO set proper inertia, copied from 4060-->
      <inertial>
        <origin xyz="0.01151002 0.5753364 0.5459604" rpy="0 0 0"/>
        <mass value="7.381808"/>
        <inertia ixx="4.347317" ixy="-0.001737663" ixz="0.00003731045" iyy="2.49037" iyz="0.02113006" izz="1.858204"/>
      </inertial>
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://hatch_xl/meshes/visual/mc_hatch_xl_frame_mirror.stl"/>
        </geometry>
        <material name="gray"/>
      </visual>
    </link>

    <joint name="${prefix}hatch_outer_frame_face_joint" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="10.0" lower="0.0" upper="1.65806" velocity="0.5"/> <!-- 95 degrees -->
      <parent link="${prefix}hatch_outer_frame"/>
      <child link="${prefix}hatch_face"/>
      <origin xyz="0.0830 2.4280 -0.06000" rpy="0 0 0"/>
      <dynamics friction="3.0" damping="3.0"/>
    </joint>

    <link name="${prefix}hatch_face">
      <!--TODO set proper inertia, copied from 4060-->
      <inertial>
        <origin xyz="-0.05635759 -0.6185068 0.5223265" rpy="0 0 0"/>
        <mass value="18.65315"/>
        <inertia ixx="5.956354" ixy="-0.02180356" ixz="0.001603986" iyy="3.823124" iyz="-0.06191432" izz="2.152308"/>
      </inertial>
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://hatch_xl/meshes/visual/mc_hatch_xl_face_mirror.stl"/>
        </geometry>
        <material name="gray"/>
      </visual>
    </link>

    <!-- Handles -->
    <xacro:include filename="$(find hatch_accessories)/urdf/grab_handle.xacro"/>

    <!-- Inside Handles -->
    <!-- Inside Exterior Horizontal Handle -->
    <xacro:grab_handle prefix="${prefix}IEH_" parent="${prefix}hatch_face">
      <origin xyz="-0.0450 -1.7391 -0.7900" rpy="0 0 0"/>
    </xacro:grab_handle>

    <!-- Inside Exterior Vertical Handle -->
    <xacro:grab_handle prefix="${prefix}IEV_" parent="${prefix}hatch_face">
      <origin xyz="-0.0450 -1.9169 -0.8504" rpy="1.5707963 0 0"/>
    </xacro:grab_handle>

    <!-- Inside Interior Horizontal Handle -->
    <xacro:grab_handle prefix="${prefix}IIH_" parent="${prefix}hatch_face">
      <origin xyz="-0.0450 -0.7391 -0.7900" rpy="0 0 0"/>
    </xacro:grab_handle>

    <!-- Inside Interior Vertical Handle -->
    <xacro:grab_handle prefix="${prefix}IIV_" parent="${prefix}hatch_face">
      <origin xyz="-0.0450 -0.9169 -0.8504" rpy="1.5707963 0 0"/>
    </xacro:grab_handle>

    <!-- Outside Handles -->
    <!-- Outside Exterior Horizontal Handle -->
    <xacro:grab_handle prefix="${prefix}OEH_" parent="${prefix}hatch_face">
      <origin xyz="-0.0700 -1.9169 -0.7900" rpy="0 0 3.1415927"/>
    </xacro:grab_handle>

    <!-- Outside Exterior Vertical Handle -->
    <xacro:grab_handle prefix="${prefix}OEV_" parent="${prefix}hatch_face">
      <origin xyz="-0.0700 -1.9169 -1.0282" rpy="-1.5707963 0 3.1415927"/>
    </xacro:grab_handle>

    <!-- Outside Interior Horizontal Handle -->
    <xacro:grab_handle prefix="${prefix}OIH_" parent="${prefix}hatch_face">
      <origin xyz="-0.0700 -0.9169 -0.7900" rpy="0 0 3.1415927"/>
    </xacro:grab_handle>

    <!-- Outside Interior Vertical Handle -->
    <xacro:grab_handle prefix="${prefix}OIV_" parent="${prefix}hatch_face">
      <origin xyz="-0.0700 -0.9169 -1.0282" rpy="-1.5707963 0 3.1415927"/>
    </xacro:grab_handle>

  </xacro:macro>
</robot>
